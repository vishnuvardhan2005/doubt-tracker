// Doubt Tracker — Prisma schema (see SPEC.md)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  OPEN
  RESOLVED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // hashed with bcrypt before storing
  role      Role
  createdAt DateTime @default(now())

  doubts         Doubt[] @relation("StudentDoubts")
  resolvedDoubts Doubt[] @relation("ResolvedDoubts")
}

model Doubt {
  id         String   @id @default(uuid())
  question   String
  subject    String
  priority   Priority @default(MEDIUM)
  status     Status   @default(OPEN)
  studentId  String
  student    User     @relation("StudentDoubts", fields: [studentId], references: [id])
  resolvedBy String?
  resolver   User?    @relation("ResolvedDoubts", fields: [resolvedBy], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
